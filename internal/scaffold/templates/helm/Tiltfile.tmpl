# Tiltfile — local development with Kind
# Run: tilt up (interactive) or tilt ci (headless/CI)

# Build the Go backend
docker_build(
    '{{.Name}}-backend',
    '.',
    dockerfile='Dockerfile.backend',
    live_update=[
        sync('./cmd', '/app/cmd'),
        sync('./internal', '/app/internal'),
    ],
)

# Build the web frontend
docker_build(
    '{{.Name}}-web',
    '.',
    dockerfile='Dockerfile.web',
    live_update=[
        sync('./web/src', '/web/src'),
    ],
)

# Deploy via Helm chart
k8s_yaml(helm(
    'deploy/helm/{{.Name}}',
    name='{{.Name}}',
    values=['deploy/helm/{{.Name}}/values.yaml'],
    set=[
        'image.repository={{.Name}}-backend',
        'image.tag=latest',
        'web.image.repository={{.Name}}-web',
        'web.image.tag=latest',
    ],
))

# Port-forward the backend API
k8s_resource('{{.Name}}', port_forwards='8080:8080')

# Port-forward the web frontend
k8s_resource('{{.Name}}-web', port_forwards='3000:8080')
