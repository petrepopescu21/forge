# AKS production overrides
replicaCount: 3

image:
  repository: {{.Name}}.azurecr.io/{{.Name}}-backend
  tag: "latest"

resources:
  limits:
    cpu: 500m
    memory: 512Mi
  requests:
    cpu: 250m
    memory: 256Mi

autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 75

podDisruptionBudget:
  enabled: true
  minAvailable: 1

affinity:
  podAntiAffinity:
    preferredDuringSchedulingIgnoredDuringExecution:
      - weight: 100
        podAffinityTerm:
          labelSelector:
            matchExpressions:
              - key: app.kubernetes.io/name
                operator: In
                values:
                  - {{.Name}}
          topologyKey: kubernetes.io/hostname

# ── Web frontend (production) ────────────────────────────────────────────────

web:
  replicaCount: 3

  image:
    repository: {{.Name}}.azurecr.io/{{.Name}}-web
    tag: "latest"

  resources:
    limits:
      cpu: 200m
      memory: 256Mi
    requests:
      cpu: 100m
      memory: 128Mi

  autoscaling:
    enabled: true
    minReplicas: 2
    maxReplicas: 10
    targetCPUUtilizationPercentage: 75

# ── Istio (production) ───────────────────────────────────────────────────────

istio:
  enabled: true
  hosts:
    - {{.Name}}.example.com
  tls:
    enabled: true
    credentialName: {{.Name}}-tls
